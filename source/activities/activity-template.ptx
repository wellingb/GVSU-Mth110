<?xml version="1.0" encoding="UTF-8"?>



<worksheet>
  <activity>
    <p>LT 4 Fining Linear Equations</p>
    
  </activity>

<<worksheet xml:id="ws-a">
  <title>Linear Graphs</title>
  <objectives>
    <ul>
      <li>Identify the slope.</li>
      <li>Identify the intercepts.</li>
      <li>Evaluate <m>f(a)</m> and find <m>x</m> when given <m>f(a)</m>.</li>
      <li>Make the equation of the line.</li>
    </ul>
  </objectives>

  <page>
    <definition xml:id="def-x">
      <statement>
        <p>Slope is the measure of the steepness and direction of a line. It is calculated as the ratio of the vertical change ("rise") to the horizontal change ("run") between any two distinct points on a line.</p>
      </statement>
    </definition>
    <definition xml:id="def-y">
      <statement>
        <p>An intercept is the point where a line or curve crosses or intersects an axis on a coordinate plane.</p>
      </statement>
    </definition>
    <image width="40%">
      <shortdescription>Graph of f of x equals x minus 2 on coordinate axes ranging from -4 to 5.</shortdescription>
      <prefigure xmlns="https://prefigure.org" label="prefigure-linear">
        <diagram dimensions="(300,300)" margins="5">
          <definition>f(x) = x - 2</definition>
          <coordinates bbox="(-4,-4,5,5)">
            <grid-axes xlabel="x" ylabel="y" hticks="(-4,1,5)" vticks="(-4,1,5)"/>
            <graph function="f"/>
          </coordinates>
        </diagram>
      </prefigure>
    </image>
    <exercise>
      <introduction>
        <p>Finding Slope</p>
      </introduction>
      <task workspace="1in">
        <statement>
          <p>How will you find the vertical change and the horizontal change?</p>
        </statement>
        <answer>
          <p>For the vertical change, find the difference of the y values. For the horizontal change, find the difference of the x values.</p>
        </answer>
      </task>
      <task workspace="2in">
        <statement>
          <p>Find the slope of the line between the two points labeled on the graph. Be sure to show your work.</p>
        </statement>
        <answer>
          <p>Using points <m>(1,-1)</m> and <m>(4,2)</m> from the graph:<md>
            <mrow>\frac{2-(-1)}{4-1} \amp= \frac{2+1}{3}</mrow>
            <mrow> \amp= \frac{3}{3}</mrow>
            <mrow> \amp= 1</mrow>
          </md></p>
          <p>The slope of the line is <m>1</m>.</p>
        </answer>
      </task>
    </exercise>
  </page>

  <page>
    <exercise xml:id="ex-mc" workspace="1.5in">
      <title>Intercepts of Linear Graphs</title>
      <statement>
        <p>In general terms, what is the correct ordered pair for the y-intercept, <m>(a,0)</m> or <m>(0,b)</m>? Explain your reasoning.</p>
      </statement>
      <answer>
        <p>The correct ordered pair is <m>(0,b)</m>. The x-value is <m>0</m> because to graph a y-intercept you start at the origin and do not move left or right, so <m>x=0</m>, then move up or down to the point <m>(0,b)</m>.</p>
      </answer>
    </exercise>
    <exercise>
      <introduction>
        <p>Finding Intercepts</p>
      </introduction>
      <task workspace="1in">
        <statement>
          <p>What is the y-intercept of the graph?</p>
        </statement>
        <answer>
          <p>The point that intersects the y-axis, or the y-intercept, is <m>(0,-2)</m>.</p>
        </answer>
      </task>
      <task workspace="1in">
        <statement>
          <p>What is the x-intercept of the graph?</p>
        </statement>
        <answer>
          <p>The point that intersects the x-axis, or the x-intercept, is <m>(2,0)</m>.</p>
        </answer>
      </task>
    </exercise>
  </page>

  <page>
    <definition xml:id="def-a">
      <statement>
        <p>Function notation is a way to write a function using symbols that show the relationship between an input and an output. Notation: <m>f(x)=y</m></p>
        <p>
          <ul>
            <li><m>f</m> — the name of the function.</li>
            <li><m>x</m> — the input of the function (also called the independent variable).</li>
            <li><m>f(x)</m> — the output when <m>x</m> is applied to the function.</li>
          </ul>
        </p>
      </statement>
    </definition>
    <exercise>
      <introduction>
        <p>Using Function Notation on the Graph of <m>f(x)</m>.</p>
      </introduction>
      <task workspace="1in">
        <statement>
          <p>Explain how you would use the graph to find <m>f(3)</m>.</p>
        </statement>
        <answer>
          <p>Go to <m>3</m> on the x-axis since we know that <m>x=3</m>. Go up or down from there until you reach the line. The y-value at that point is your answer.</p>
        </answer>
      </task>
      <task workspace="0.75in">
        <statement>
          <p>Use the graph to find <m>f(3)</m>.</p>
        </statement>
        <answer>
          <p>The point where <m>x=3</m> is <m>(3,1)</m>. This tells us <m>f(3)=1</m>.</p>
        </answer>
      </task>
      <task workspace="1in">
        <statement>
          <p>Explain how you would use the graph to find <m>x</m> when <m>f(x)=-4</m>.</p>
        </statement>
        <answer>
          <p>Go to <m>-4</m> on the y-axis since we know that <m>y=-4</m>. Go left or right from there until you reach the line. The x-value at that point is your answer.</p>
        </answer>
      </task>
      <task workspace="0.75in">
        <statement>
          <p>Use the graph to find <m>x</m> when <m>f(x)=-4</m>.</p>
        </statement>
        <answer>
          <p>The point where <m>y=-4</m> is <m>(-2,-4)</m>. This tells us <m>x=-2</m> when <m>f(x)=-4</m>.</p>
        </answer>
      </task>
    </exercise>
  </page>

  <page>
    <definition xml:id="def-b">
      <statement>
        <p>A linear equation is an equation that forms a straight line when graphed. It has variables raised only to the first power (no squares, cubes, or roots of variables). The general form is: <m>y=mx+b</m></p>
        <p>
          <ul>
            <li><m>y</m> — the output of the function (also called the dependent variable).</li>
            <li><m>x</m> — the input of the function (also called the independent variable).</li>
            <li><m>m</m> — the slope of the line (the steepness and direction).</li>
            <li><m>b</m> — the y-intercept of the line (where it crosses the y-axis).</li>
          </ul>
        </p>
      </statement>
    </definition>
    <exercise>
      <introduction>
        <p>Finding the Equation of the Graph of <m>f(x)</m>.</p>
      </introduction>
      <task workspace="1in">
        <statement>
          <p>What is the <m>m</m> of the graph <m>f(x)</m>? Explain how you know.</p>
        </statement>
        <answer>
          <p>The <m>m</m> is the slope. We found the slope of <m>f(x)</m> is <m>1</m>, so <m>m=1</m>.</p>
        </answer>
      </task>
      <task workspace="1in">
        <statement>
          <p>What is the <m>b</m> of the graph <m>f(x)</m>? Explain how you know.</p>
        </statement>
        <answer>
          <p>The <m>b</m> is the y-intercept. We found the y-intercept of <m>f(x)</m> is <m>(0,-2)</m>, so <m>b=-2</m>.</p>
        </answer>
      </task>
      <task workspace="1.5in">
        <statement>
          <p>What is the equation of the graph <m>f(x)</m>? Explain how you know.</p>
        </statement>
        <answer>
          <p>Substituting <m>m=1</m> and <m>b=-2</m> into the general form <m>y=mx+b</m> gives <m>f(x)=x-2</m>.</p>
        </answer>
      </task>
    </exercise>
  </page>

</worksheet>
</worksheet>
  