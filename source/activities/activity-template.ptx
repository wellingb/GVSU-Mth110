<worksheet>
 <title>Linear Characteristics</title>

<page>
<exercise>
  

<statement>
  <p>
    For each representation below:
    <ul>
      <li>
        <p>
          Find or indicate the vertical intercept.
        </p>
      </li>
      <li>
        <p>Find or indicate the slope.
         
        </p>
      </li>
      <li>
        <p>
          Explain the behavior of the line and your reasoning for your answer.
        </p>
      </li>
      <li>
        <p>
          Find the equation of the line represented.
        </p>
      </li>
    </ul>
  </p>
  <tabular top="minor" bottom="medium" left="major" right="major">
    <col width="60%" halign="center" />
    <col width="40%" halign="center" />
   <row header="yes" halign="center" >
    <cell>Representation</cell>
    <cell>Vertical Intercept</cell>
    <cell>Slope</cell>
    <cell>Behavior (Incr/Decr/Vertical/Horz)</cell>
    <cell>Equation</cell>
      </row>
  <row halign="center">
    <cell><prefigure xmlns="https://prefigure.org"
             label="prefigure-rectangle-b">
    <diagram dimensions="(300,300)" margins="5">
      <definition>f(x)=(x-2)</definition>
      <coordinates bbox="(-4,-4,5,5)">
        <grid-axes xlabel="x" ylabel="y" hticks="(-4,1,5)" vticks="(-4,1,5)"/>
         <graph function="f"/>
      </coordinates>
    </diagram>
  </prefigure></cell>
    <cell></cell>
    <cell></cell>
    <cell></cell>
    <cell></cell>
  </row>
 
  <row halign="center">
    <cell><prefigure xmlns="https://prefigure.org"
             label="prefigure-rectangle">
    <diagram dimensions="(300,300)" margins="5">
      <definition>f(x)=(-x+3)</definition>
      <coordinates bbox="(-4,-4,5,5)">
        <grid-axes xlabel="x" ylabel="y" hticks="(-4,1,5)" vticks="(-4,1,5)"/>
         <graph function="f"/>
      </coordinates>
    </diagram>
  </prefigure></cell>
    <cell></cell>
    <cell></cell>
    <cell></cell>
    <cell></cell>
   
  </row>
