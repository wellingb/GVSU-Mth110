<worksheet>
  <title>LT 4:Linear Equations</title>
  <objectives>
    <ul>
      <li>Find the equation of a table of linear data</li>
       <li>Find the equation of a line parallel or perpendicular to a given line's graph.
      </li>
       <li>Find the equation of a line given a point and slope.
      </li>
      <li>Find the equation of a line given two points..
      </li>
     
    </ul>
  </objectives>
 <page>
  <tabular top="minor" bottom="minor" left="minor" right="minor">
  <col>width=5% halign="center"</col>
  <col>width=50% halign="center"</col>
  <row header="yes" halign="center" >
    <cell>x</cell>
    <cell>f(x)</cell>
    <cell></cell>
    <cell>x</cell>
    <cell>g(x)</cell>
    <cell></cell>
    <cell>x</cell>
    <cell>h(x)</cell>
  </row>
  <row halign="center">
    <cell>-1</cell>
    <cell>-15</cell>
    <cell></cell>
    <cell>0</cell>
    <cell>9</cell>
    <cell></cell>
    <cell>3</cell>
    <cell>-1</cell>
  </row>
  <row halign="center">
    <cell>0</cell>
    <cell>-9</cell>
    <cell></cell>
    <cell>1</cell>
    <cell>5</cell>
    <cell></cell>
    <cell>6</cell>
    <cell>1</cell>
  </row>
  <row halign="center">
    <cell>1</cell>
    <cell>-3</cell>
    <cell></cell>
    <cell>2</cell>
    <cell>1</cell>
    <cell></cell>
    <cell>9</cell>
    <cell>3</cell>
  </row>
  <row halign="center">
    <cell>2</cell>
    <cell>3</cell>
    <cell></cell>
    <cell>3</cell>
    <cell>-3</cell>
    <cell></cell>
    <cell>12</cell>
    <cell>5</cell>
  </row>
  <row halign="center">
    <cell>3</cell>
    <cell>9</cell>
    <cell></cell>
    <cell>4</cell>
    <cell>-7</cell>
    <cell></cell>
    <cell>15</cell>
    <cell>7</cell>
