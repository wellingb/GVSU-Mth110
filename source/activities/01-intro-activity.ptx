<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet>
      <title>Practice Activity</title>
      <page>
        <exercise>
          <statement>
            <p>Find the slope between <m>(1,-1)</m> and <m>(4,2)</m>.</p>
          </statement>
          <answer>
            <p>The slope is <m>1</m>.</p>
          </answer>
        </exercise>
        <image width="60%">
  <prefigure xmlns="https://prefigure.org"
             label="prefigure-rectangle1">
    <diagram dimensions="(300,300)" margins="5">
      <definition>f(x)=(x-2)</definition>
      <coordinates bbox="(-4,-4,5,5)">
        <grid-axes xlabel="x" ylabel="y" hticks="(-4,1,5)" vticks="(-4,1,5)"/>
         <graph function="f"/>
      </coordinates>
    </diagram>
  </prefigure>
</image>
 
<figure xml:id="fig-01-01-2-nonlinear-pattern">
  <caption>A visual pattern where the number of stars is increasing.</caption>
  <image source="01-01-2-nonlinear_pattern_stars.svg">
    <shortdescription>A pattern where at step 1 there is 1 star, at step 2 there are 2 stars, at step 3 there are 4 stars, and at step 4 there are 7 stars.</shortdescription>
  </image>
</figure>

  
      </page>
      
         

      
    </worksheet>
  