
<image width="40%">
      <shortdescription>Graph of f of x equals 3 times 2 to the x on coordinate axes ranging from -4 to 15.</shortdescription>
      <prefigure xmlns="https://prefigure.org" label="prefigure-exponential-1">
        
<diagram dimensions="(300,300)" margins="5">
<definition>f(x)=3*(2)^x</definition>
<coordinates bbox="(-4,-4,3,15)">
<grid-axes xlabel="x" ylabel="y" hticks="(-4,1,3)" vticks="(-2.5,2.5,15)"/>
<graph function="f"/>
</coordinates>
</diagram>
</prefigure>
</image>
