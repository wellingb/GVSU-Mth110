<exercise workspace="0.01 in">
    <introduction>
        <p>
            Imagine you won $15,000 in the lottery. You decide to make the responsible choice and put your winnings into a savings account that yields 6% interest annually. 

        </p>
    </introduction>
</exercise>
<task workspace="0.01 in">
    <statement>
        <p>
           What is the initial value? What is the growth factor?
 
        </p>
    </statement>
</task>
<task workspace="0.01 in">
    <statement>
        <p>
           Write an equation that will model the balance in the savings account over x number of years.
        </p>
    </statement>
</task>
<task workspace="0.01 in">
    <statement>
        <p>
           Use your equation to determine the balance of your savings account in 5 years. 
        </p>
    </statement>
</task>
<task workspace="0.01 in">
    <statement>
        <p>
           How many years will it take for you to have $30,000? (assuming no additional money is added)
        </p>
    </statement>
</task>

<exercise>
    <introduction>
        <p>
            Imagine instead that you used your winnings to buy a car worth $15,000 that is depreciating at a rate of 16% annually.

        </p>
    </introduction>
</exercise>
<task workspace="0.01 in"> 
    <statement>
        <p>
          What is the initial value? What is the decay factor?  
        </p>
    </statement>
</task>
<task workspace="0.01 in">
    <statement>
        <p>
            Write an equation that will model the value of the car over x number of years. 
        </p>
    </statement>
</task>
<task workspace="0.01 in">
    <statement>
        <p>
            Use your equation to determine the value of your car in 5 years. 
        </p>
    </statement>
</task>
<task workspace="0.01 in">
    <statement>
        <p>
            How many years will it take for your car to be worth $5,000? (assuming no additional money is added)     
        </p>
    </statement>
</task>

</worksheet>

