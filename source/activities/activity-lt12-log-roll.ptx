        <statement>
            <p>
                <m>x=log_b(a)</m> then <m>x*log</m>(_____) = <m>log</m>(_____).

            </p>
        </statement>
    </task>
    <task workspace="0.01in">
        <statement>
            <p>
                <m>\log_b(a) = \frac{\log(\underline{\text{      }})}{\log(\underline{\text{      }})}</m>
            </p>
            
        </statement>
    </task>
</exercise>
