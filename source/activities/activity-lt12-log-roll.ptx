<worksheet>
<title>LT 12 Log Rolling</title>
<exercise>
    <introduction>
        <p>
            Use Desmos to evaluate each lexponential and log equation.  A table for work is provided after the equation circle. 

        </p>
        <p>
             Match equivalent expressions by drawing a line.  After calculating the value for <m></m> in each equation, you should be able to draw at least one line for each equation
        </p>
    <image source="log-roll.png">
        <shortdescription>circle of log equations</shortdescription>
    </image>
    <tabular top="minor" bottom="medium" left="major" right="major">
  <title>Systems Parmaeters</title>
  <col>width=50% halign="center"</col>
  <col>width=50%</col>
  <row header="yes" halign="center" >
    <cell><p><m>5^x=3</m></p>
        <p>&#160;</p></cell>
    <cell><p><m>log_x5=5</m></p>
        <p>&#160;</p></cell>
             </row>
  <row halign="center">
  <cell><p><m>3^x=5</m></p>
        <p>&#160;</p></cell>
    <cell><p><m>\frac{log5}{log3}</m></p>
        <p>&#160;</p></cell>
  </row>
  <row header="yes" halign="center" >
    <cell><p><m>3^5=x</m></p>
          <p>&#160;</p></cell>
    <cell><p><m>log_5x=3</m></p>
            <p>&#160;</p></cell>
             </row>
    <row header="yes" halign="center" >
    <cell><p><m>x^3=5</m></p>
          <p>&#160;</p></cell>
    <cell><p><m>log_35=x</m></p>
    <p>&#160;</p></cell>
             </row>
    <row header="yes" halign="center" >
    <cell><p><m>5^3=x</m></p>
          <p>&#160;</p></cell> 
    <cell><p><m>log_53=x</m></p>
          <p>&#160;</p></cell>
             </row>
    <row header="yes" halign="center" >
    <cell><p><m>\sqrt{3}=5</m></p>
           <p>&#160;</p></cell> 
    <cell><p><m>xlog5=log3</m></p>
    <p>&#160;</p></cell> 
             </row>
    <row header="yes" halign="center" >
    <cell><p><m>x=5^{\frac{1}{3}}</m></p>
    <p>&#160;</p></cell>
    <cell><p><m>log_3x=5</m></p>
    <p>&#160;</p></cell>
             </row>
    </tabular>
    </introduction>
</exercise>
<page>
<exercise>
    <introduction>
        <p>
            Use your results to generalize your findings for the following properties.
        </p>
    </introduction>
